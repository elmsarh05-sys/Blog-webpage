{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "posts": {
      ".read": "true",
      ".write": "auth != null",
      ".indexOn": ["author_id", "status"]
    },
    "comments": {
      ".read": "true",
      ".write": "auth != null",
      ".indexOn": ["post_id"]
    }
  }
}
